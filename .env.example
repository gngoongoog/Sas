# SuperSAS v4 Backend Configuration Environment Variables

# Server Port (Bound and routed on 3000)
PORT=3000

# Base admin login credential configurations
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# JWT Cryptographic Private Token Key (Secure logins)
JWT_SECRET=supersas_jwt_default_secret_key_102830

# Router sensitive password AES encryption key (32 character string)
ENCRYPTION_KEY=supersas_default_secret_32bytes_!

# AI Copilot engine access token
GEMINI_API_KEY=

# Optionals: Live Notifications Bot integration tokens
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID
